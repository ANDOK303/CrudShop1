DROP DATABASE IF EXISTS storeDb_in5bv;
CREATE DATABASE storeDb_in5bv;
USE storeDb_in5bv;

-- 1. Tables Creation
CREATE TABLE users (
    userId INT AUTO_INCREMENT PRIMARY KEY,
    firstName VARCHAR(60) NOT NULL,
    lastName VARCHAR(60) NOT NULL,
    age INT NOT NULL,
    email VARCHAR(100) NOT NULL -- Nuevo Atributo
);

CREATE TABLE categories (
    categoryId INT AUTO_INCREMENT NOT NULL PRIMARY KEY,
    categoryName VARCHAR(60) NOT NULL,
    categoryDescription VARCHAR(150),
    isActive BOOLEAN DEFAULT TRUE -- Nuevo Atributo
);

CREATE TABLE products (
    productId INT AUTO_INCREMENT NOT NULL PRIMARY KEY,
    productName VARCHAR(80) NOT NULL,
    productPrice DECIMAL(10,2) NOT NULL,
    stock INT NOT NULL,
    brand VARCHAR(50), -- Nuevo Atributo
    category_id INT NOT NULL,
    CONSTRAINT fk_product_category
        FOREIGN KEY (category_id)
        REFERENCES categories(categoryId)
);

CREATE TABLE orders (
    orderId INT AUTO_INCREMENT NOT NULL PRIMARY KEY,
    orderDate VARCHAR(60) NOT NULL,
    orderTotal DECIMAL(10,2) NOT NULL,
    shippingAddress VARCHAR(150), -- Nuevo Atributo
    user_id INT NOT NULL,
    CONSTRAINT fk_order_user
        FOREIGN KEY (user_id)
        REFERENCES users(userId)
);

CREATE TABLE details (
    detailId INT AUTO_INCREMENT NOT NULL PRIMARY KEY,
    quantity INT NOT NULL,
    unitPrice DECIMAL(10,2) NOT NULL,
    subtotal DECIMAL(10,2) NOT NULL, -- Nuevo Atributo
    order_id INT NOT NULL,
    product_id INT NOT NULL,
    CONSTRAINT fk_detail_order
        FOREIGN KEY (order_id)
        REFERENCES orders(orderId),
    CONSTRAINT fk_detail_product
        FOREIGN KEY (product_id)
        REFERENCES products(productId)
);

